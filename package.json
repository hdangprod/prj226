{
  "name": "telegram-notion-second-brain",
  "version": "1.0.0",
  "description": "Serverless Telegram Bot orchestrating a Notion Second Brain via Gemini AI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npx @google-cloud/functions-framework --target=helloHttp --source=dist",
    "test": "npx ts-node tests/localTest.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "deploy": "npm run build && gcloud functions deploy telegram-notion-bot --entry-point helloHttp --runtime nodejs20 --trigger-http --allow-unauthenticated"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/functions-framework": "^3.5.1",
    "@google-cloud/tasks": "^3.1.2",
    "@google/generative-ai": "^0.21.0",
    "@notionhq/client": "^2.2.15",
    "dotenv": "^16.4.5",
    "googleapis": "^173.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
