FROM node:20-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app

COPY package*.json ./
RUN npm ci
COPY . .

RUN chmod -R +x .agents/skills/orchestrator/scripts/

CMD ["node", ".agents/skills/orchestrator/scripts/supreme_assistant.js"]
